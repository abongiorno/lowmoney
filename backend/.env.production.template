# Production Environment Variables Template
# Copiare questo file in .env.production e inserire i valori reali

# Server Configuration
PORT=80
NODE_ENV=production
FRONTEND_URL=https://your-frontend-url.azurestaticapps.net

# Azure Cosmos DB Configuration
COSMOS_ENDPOINT=https://lowmoney-cosmosdb.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key-from-azure-portal
COSMOS_DATABASE_NAME=LowMoneyDB

# Authentication
JWT_SECRET=your-super-secure-production-jwt-secret-at-least-32-chars

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=lowmoneystorage;AccountKey=your-storage-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=lowmoney-images